# Server
PORT=5001

# PostgreSQL (Supabase) — use Session pooler URL if your network is IPv4-only
# Single URL is enough for the `pg` package:
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# MongoDB Atlas — from Cluster → Connect → Drivers (replace <password> with DB user password)
# Include database name in the path, e.g. .../ecommerce?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority

# Optional: for cookies/sessions later (generate a long random string)
# SESSION_SECRET=
